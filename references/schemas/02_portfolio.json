{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "market-analyst/portfolio/v1.0",
  "title": "Portfolio Gate",
  "description": "Stage 2 output: portfolio gate decision and portfolio data (if available).",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "mode",
    "checked_at",
    "portfolio"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "report_id": {
      "type": "string",
      "description": "Must match the report_id from Stage 1 trigger."
    },
    "mode": {
      "type": "string",
      "enum": ["with_portfolio", "without_portfolio"],
      "description": "Mode A = with_portfolio (personalized), Mode B = without_portfolio (public only)."
    },
    "checked_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the portfolio gate check was performed."
    },
    "portfolio": {
      "type": ["object", "null"],
      "description": "Portfolio data. Must be null when mode is 'without_portfolio'.",
      "required": ["owner_id", "currency", "holdings", "recent_trades"],
      "properties": {
        "owner_id": {
          "type": "string",
          "description": "Anonymized owner identifier. Never store real names in pipeline JSON."
        },
        "currency": {
          "type": "string",
          "enum": ["TWD", "USD", "HKD", "CNY"],
          "description": "Base currency for P&L calculations."
        },
        "as_of_date": {
          "type": "string",
          "format": "date",
          "description": "Date the portfolio snapshot was taken."
        },
        "holdings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ticker", "exchange", "shares", "cost_basis_per_share", "cost_basis_currency"],
            "properties": {
              "ticker": {
                "type": "string",
                "pattern": "^[A-Z0-9.]{1,10}$"
              },
              "exchange": {
                "type": "string",
                "enum": ["NYSE", "NASDAQ", "TWSE", "HKEX", "SSE", "SZSE", "OTHER"],
                "description": "Exchange the holding is listed on."
              },
              "shares": {
                "type": "string",
                "pattern": "^\\d+(\\.\\d+)?$",
                "description": "Number of shares held. Decimal-safe string."
              },
              "cost_basis_per_share": {
                "type": "string",
                "pattern": "^\\d+(\\.\\d+)?$",
                "description": "Average cost basis per share. Decimal-safe string."
              },
              "cost_basis_currency": {
                "type": "string",
                "enum": ["TWD", "USD", "HKD", "CNY"]
              },
              "sector": {
                "type": ["string", "null"],
                "description": "Sector classification. Null if unknown."
              }
            }
          }
        },
        "recent_trades": {
          "type": "array",
          "description": "Trades within the report's relevant period.",
          "items": {
            "type": "object",
            "required": ["ticker", "action", "shares", "price_per_share", "currency", "executed_at"],
            "properties": {
              "ticker": {
                "type": "string",
                "pattern": "^[A-Z0-9.]{1,10}$"
              },
              "action": {
                "type": "string",
                "enum": ["buy", "sell"]
              },
              "shares": {
                "type": "string",
                "pattern": "^\\d+(\\.\\d+)?$"
              },
              "price_per_share": {
                "type": "string",
                "pattern": "^\\d+(\\.\\d+)?$"
              },
              "currency": {
                "type": "string",
                "enum": ["TWD", "USD", "HKD", "CNY"]
              },
              "executed_at": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp of trade execution."
              },
              "fees": {
                "type": ["string", "null"],
                "pattern": "^\\d+(\\.\\d+)?$",
                "description": "Transaction fees. Decimal-safe string. Null if unknown."
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "report_id": "post_market_20260317_170000",
      "mode": "with_portfolio",
      "checked_at": "2026-03-17T16:51:00-04:00",
      "portfolio": {
        "owner_id": "usr_a1b2c3",
        "currency": "TWD",
        "as_of_date": "2026-03-17",
        "holdings": [
          {
            "ticker": "2330.TW",
            "exchange": "TWSE",
            "shares": "1000",
            "cost_basis_per_share": "580.00",
            "cost_basis_currency": "TWD",
            "sector": "semiconductors"
          },
          {
            "ticker": "AAPL",
            "exchange": "NASDAQ",
            "shares": "50",
            "cost_basis_per_share": "178.50",
            "cost_basis_currency": "USD",
            "sector": "technology"
          }
        ],
        "recent_trades": [
          {
            "ticker": "2330.TW",
            "action": "buy",
            "shares": "500",
            "price_per_share": "575.00",
            "currency": "TWD",
            "executed_at": "2026-03-15T09:15:00+08:00",
            "fees": "800.00"
          }
        ]
      }
    }
  ]
}